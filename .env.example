NODE_ENV=production
BOT_PREFIX=!
SESSION_DIR=./session
# Default command binary paths (virtualenv)
SHERLOCK_CMD=./.venv/bin/sherlock
SHERLOCK_WORKDIR=./runtime
SHERLOCK_TIMEOUT_MS=180000
SHERLOCK_MAX_OUTPUT_CHARS=3500
HOLEHE_CMD=./.venv/bin/holehe
HOLEHE_WORKDIR=./runtime/holehe
HOLEHE_TIMEOUT_MS=180000
HOLEHE_MAX_OUTPUT_CHARS=3500
MAIGRET_CMD=./.venv/bin/maigret
MAIGRET_WORKDIR=./runtime/maigret
MAIGRET_TIMEOUT_MS=180000
MAIGRET_MAX_OUTPUT_CHARS=3500
INSTALOADER_CMD=./.venv/bin/instaloader
INSTALOADER_WORKDIR=./runtime/instaloader
INSTALOADER_TIMEOUT_MS=180000
INSTALOADER_MAX_OUTPUT_CHARS=3500
THEHARVESTER_CMD=./.venv/bin/theHarvester
THEHARVESTER_WORKDIR=./runtime/theharvester
THEHARVESTER_TIMEOUT_MS=180000
THEHARVESTER_MAX_OUTPUT_CHARS=3500
GOOGLE_DORK_DOC_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx
GOOGLE_DORK_DEFAULT_SITE=
GOOGLE_DORK_MAX_RESULTS=20
WHATSAPP_SEND_QR_TO_TERMINAL=true
WHATSAPP_OWNER_JID=628xxxxxxxxxx@s.whatsapp.net
X_BEARER_TOKEN=
PG_URL=postgres://user:pass@localhost:5432/cicero_db
X_ISSUE_HUNTER_WORKDIR=./runtime/x-issue-hunter

TIKTOK_RAPIDAPI_KEY=
TIKTOK_RAPIDAPI_HOST=tiktok-api23.p.rapidapi.com
TIKTOK_RAPIDAPI_BASE_URL=https://tiktok-api23.p.rapidapi.com
TIKTOK_RAPIDAPI_SEARCH_PATH=/api/search/video
TIKTOK_RAPIDAPI_MAX_COUNT=20
TIKTOK_ISSUE_HUNTER_WORKDIR=./runtime/tiktok-issue-hunter
